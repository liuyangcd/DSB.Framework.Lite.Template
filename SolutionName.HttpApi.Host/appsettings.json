{
  "FileUploadOptions": {
    "FileMaxSize": 1024,
    "SavePath": "UploadFiles",
    "FileTypeOptions": {
      "Pictrue": {
        "Extensions": ".jpg,.jpeg,.png,.gif,.bmp",
        "MaxSize": 20
      },
      "Video": {
        "Extensions": ".mp4,.mkv,.webm",
        "MaxSize": 1024
      },
      "Audio": {
        "Extensions": ".mp3,.aac,.flac,",
        "MaxSize": 200
      },
      "Document": {
        "Extensions": ".doc,.docx,.xls,.xlsx,.json,.txt,.pdf",
        "MaxSize": 100
      },
      "Attachment": {
        "Extensions": ".zip,.tar",
        "MaxSize": 1024
      }
    }
  }
}
